# --- Server ---
PORT=3001
# Comma-separated list of allowed front-end origins (web + dashboard)
CORS_ORIGINS=http://localhost:3003,http://localhost:3002

# --- Database (PostgreSQL via Prisma) ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public
DATABASE_URL="postgresql://DB_USERNAME:DB_PASSWORD@127.0.0.1:5432/DB_NAME?schema=public"

# --- Auth (admin dashboard login) ---
JWT_SECRET=change-me-to-a-long-random-string
ADMIN_EMAIL=admin@crestviewgroup.com
ADMIN_PASSWORD=crestview123

# --- Google Gemini ---
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
# Faster/cheaper second model, tried automatically if the primary fails (e.g. rate limit)
GEMINI_MODEL_FALLBACK=gemini-3.1-flash-lite
