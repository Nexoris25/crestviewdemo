# --- Server ---
PORT=3001
# Comma-separated list of allowed front-end origins (web + dashboard)
CORS_ORIGINS=http://localhost:3000,http://localhost:3002

# --- Database (SQLite via Prisma) ---
DATABASE_URL="file:./dev.db"

# --- Auth (admin dashboard login) ---
JWT_SECRET=change-me-to-a-long-random-string
ADMIN_EMAIL=admin@crestviewgroup.com
ADMIN_PASSWORD=crestview123

# --- Google Gemini ---
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
# Faster/cheaper second model, tried automatically if the primary fails (e.g. rate limit)
GEMINI_MODEL_FALLBACK=gemini-3.1-flash-lite
