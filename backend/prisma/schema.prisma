// CrestView leads database (PostgreSQL via Prisma).
// A few list fields (reasons, toneSignals) are stored as JSON-encoded strings.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id        String  @id @default(cuid())

  // Submitted by the contact form
  fullName  String
  company   String
  email     String
  phone     String?
  location  String?
  service   String? // service of interest
  message   String
  consent   Boolean @default(false)
  source    String  @default("website")

  // AI (Gemini) analysis
  status      String  @default("New") // Hot | Warm | Cold | New
  score       Int     @default(0) // 0 - 100
  summary     String?
  reasons     String? // JSON: string[]
  toneSignals String? // JSON: string[]
  nextStep    String?
  emailSubject String?
  emailBody    String?
  aiPowered    Boolean @default(false) // true when Gemini produced the analysis

  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  activities Activity[]

  @@index([status])
  @@index([createdAt])
}

model Activity {
  id      String  @id @default(cuid())
  type    String // lead_submitted | email_generated | status_updated | ai_analysis
  message String
  leadId  String?
  lead    Lead?   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([createdAt])
}
